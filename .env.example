# Copy this file to .env and fill in your values
# cp .env.example .env

# Embedding providers (set the one you use)
OPENAI_API_KEY=
COHERE_API_KEY=

# Cloud sources (set the ones you use)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=

# Google Cloud (uses Application Default Credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Qdrant (if using API key auth)
QDRANT_API_KEY=
QDRANT_URL=http://localhost:6333

# Pinecone
PINECONE_API_KEY=

# Webhook (optional)
WEBHOOK_URL=

# Auto-install missing dependencies without prompting
# TRIBUTARY_AUTO_INSTALL=1

# ---------------------------------------------------------------------------
# Distributed mode — queue backends
# Set only the block for the backend you're using. Each example script in
# examples/distributed/ reads these via os.getenv().
# ---------------------------------------------------------------------------

# Redis (examples/distributed/redis_example.py)
REDIS_URL=redis://localhost:6379

# AWS SQS (examples/distributed/sqs_example.py)
# Reuses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above.
AWS_REGION=us-east-1
DOCUMENT_QUEUE_URL=
CHUNK_QUEUE_URL=

# RabbitMQ (examples/distributed/rabbitmq_example.py)
RABBITMQ_URL=amqp://guest:guest@localhost/

# Google Cloud Pub/Sub (examples/distributed/pubsub_example.py)
# Reuses GOOGLE_APPLICATION_CREDENTIALS above for auth.
GCP_PROJECT=

# Azure Service Bus (examples/distributed/servicebus_example.py)
# Copy the connection string from "Shared access policies" in the Azure portal.
SERVICE_BUS_CONNECTION_STRING=

# Apache Kafka (examples/distributed/kafka_example.py)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
