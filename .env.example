# Copy this file to .env and fill in your values
# cp .env.example .env

# Embedding providers (set the one you use)
OPENAI_API_KEY=
COHERE_API_KEY=

# Cloud sources (set the ones you use)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=

# Google Cloud (uses Application Default Credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Qdrant (if using API key auth)
QDRANT_API_KEY=
QDRANT_URL=http://localhost:6333

# Pinecone
PINECONE_API_KEY=

# Webhook (optional)
WEBHOOK_URL=

# Auto-install missing dependencies without prompting
# TRIBUTARY_AUTO_INSTALL=1
